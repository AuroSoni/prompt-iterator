# Supabase connection for the library store.
#
# Copy this file to .env.local (git-ignored) and fill in the two values from
# your Supabase project's API settings. Leave them blank to run the app on
# in-memory sample data with no backend.
#
# Only the PUBLISHABLE anon key belongs here — it is safe in client code.
# Never put a service-role key or a personal access token in any .env file.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
