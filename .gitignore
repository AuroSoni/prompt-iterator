# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env — real keys live in .env.local (ignored by *.local above). These extra
# lines make sure a plain .env can never be committed to this public repo;
# .env.example is the tracked template.
.env
.env.*
!.env.example

